{
  "name": "@tegaki/website",
  "version": "0.17.0",
  "private": true,
  "type": "module",
  "description": "Documentation and demo website for Tegaki",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/KurtGokhan/tegaki.git",
    "directory": "packages/website"
  },
  "imports": {
    "#*": "./*"
  },
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
