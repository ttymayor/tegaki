{
  "name": "tegaki",
  "version": "0.16.0",
  "type": "module",
  "description": "Framework-agnostic animated handwriting renderer with React, Svelte, Vue, Nuxt, SolidJS, Astro, and Web Components adapters",
  "keywords": [
    "handwriting",
    "animation",
    "svg",
    "react",
    "svelte",
    "vue",
    "solid",
    "astro",
    "nuxt",
    "web-components",
    "custom-elements",
    "font",
    "calligraphy",
    "stroke-order",
    "text-animation",
    "writing-animation"
  ],
  "homepage": "https://github.com/KurtGokhan/tegaki#readme",
  "bugs": {
    "url": "https://github.com/KurtGokhan/tegaki/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/KurtGokhan/tegaki.git",
    "directory": "packages/renderer"
  },
  "license": "MIT",
  "author": {
    "name": "Gokhan Kurt",
    "email": "krtgkn@gmail.com",
    "url": "https://gkurt.com"
  },
  "exports": {
    ".": {
      "tegaki@dev": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./core": {
      "tegaki@dev": "./src/core/index.ts",
      "source": "./src/core/index.ts",
      "types": "./dist/core/index.d.mts",
      "import": "./dist/core/index.mjs"
    },
